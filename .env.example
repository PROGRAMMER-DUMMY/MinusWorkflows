# ── MinusWorkflows: copy this to .env and edit ───────────────────────────────
#
# MODE controls behaviour at runtime — no rebuild needed to switch lite ↔ standard.
# Switching to full requires: docker-compose build --build-arg FEATURES=ner
#
#   lite      disk cache · regex scrubbing · instant start
#   standard  Redis cache · regex scrubbing · instant start
#   full      Redis cache · NER scrubbing  · instant start (model pre-baked in image)
#
MODE=lite

# Docker image for the OCR-Memory service (pulled automatically by `minus start`)
# Default points to the published image. Override to use a private registry or a
# specific version tag (e.g. ghcr.io/programmer-dummy/minusworkflows:v2.0.1).
# OCR_MEMORY_IMAGE=ghcr.io/programmer-dummy/minusworkflows:latest

# Database (required)
POSTGRES_USER=ocrmemory
POSTGRES_PASSWORD=changeme        # ← change this

# Authentication — protects /memory/store and /memory/retrieve
# Set to a strong random string (e.g. openssl rand -hex 32).
# Leave empty to disable auth (development only).
API_KEY=

# Build arg — only needed when switching TO full mode:
#   docker-compose build --build-arg FEATURES=ner
BUILD_FEATURES=

# Vision API for optical retrieval (optional — text search is the fallback)
# Set VISION_BACKEND to one of: anthropic, openai, google
# VISION_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Override which model is used for vision API calls (optional)
# VISION_MODEL_ANTHROPIC=claude-sonnet-4-6
# VISION_MODEL_OPENAI=gpt-4o

# Semantic embeddings via pgvector (optional — enables real vector search)
# Set EMBEDDING_BACKEND=openai and provide OPENAI_API_KEY above.
# EMBEDDING_BACKEND=openai
# EMBEDDING_MODEL=text-embedding-3-small

# Agent provider — controls how sub-agents are invoked
#
#   OPTION A: CLI binary (default)
#     Supported built-ins: claude (default), gemini, openai
#     Custom: set AGENT_CLI=custom and provide AGENT_CLI_TEMPLATE
#
# AGENT_CLI=claude
# AGENT_DEFAULT_MODEL=claude-sonnet-4-6
# AGENT_FAST_MODEL=claude-haiku-4-5-20251001   # used for cheap tasks (memory pruning etc.)
# AGENT_CLI_TEMPLATE=my-cli -p {prompt} --model {model}
#
#   OPTION B: HTTP API (no CLI binary needed — works with any provider)
#     Set AGENT_PROVIDER=http and configure the endpoint below.
#     Supported formats: anthropic | openai | google
#     Any OpenAI-compatible endpoint works with AGENT_API_FORMAT=openai.
#
# AGENT_PROVIDER=http
# AGENT_API_URL=https://api.anthropic.com/v1/messages
# AGENT_API_KEY=sk-ant-...
# AGENT_API_FORMAT=anthropic

# Admin key — required for key management (/keys) and retention (/admin/retention/run)
# Generate: openssl rand -hex 32
# ADMIN_KEY=

# Retention policy
# RETENTION_TTL_DAYS=90        # hard-delete episodes older than N days (unset = disabled)
# RETENTION_MAX_EPISODES=500   # per-project episode cap — oldest beyond cap are deleted (unset = disabled)
# RETENTION_ARCHIVE=true       # copy PNGs to .vault/archive/{project_id}/ before deleting

# Pipeline retry limit — max attempts per phase before halting with DIAGNOSTIC.md
# PIPELINE_RETRY_LIMIT=3

# OCR-Memory API rate limit — max requests per minute per API key (default: 60)
# RATE_LIMIT_RPM=60
#
# NOTE: rate limiting is per-instance in-memory and resets on restart.
# For multi-instance / load-balanced deployments, rate limits are NOT shared
# across instances. Redis-backed rate limiting is a planned future item.
# Single-container deployments (the default docker-compose setup) are unaffected.

# Webhook — fired after every store and retrieve (fire-and-forget POST, 5s timeout)
# Payload: { event, project_id, episode_id, events_count, timestamp, req_id }
# WEBHOOK_URL=https://your-service.example.com/hooks/ocr-memory

# Long-horizon context — tiered injection budget
# How many tokens of prior-phase context to inject into each sub-agent prompt.
# Older phases are demoted: full artifacts → receipt JSON → one-line summary.
# CONTEXT_BUDGET_TOKENS=60000

# Long-horizon reliability — streaming spawn inactivity watchdog
# Kill a CLI sub-agent if it produces no output for this many milliseconds.
# Only applies to CLI provider path (HTTP provider uses its own timeout).
# PHASE_IDLE_TIMEOUT_MS=300000

# Override the test command used by the phase verifier (auto-detected by default).
# PHASE_VERIFY_CMD=npm test

# Logging
RUST_LOG=info,ocr_memory_rust=debug
